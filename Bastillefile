# --- Variable ---

ARG CPULIMIT="0,1"
ARG MEMLIMIT="2048M"
ARG DISKLIMIT="4G"

ARG PG_VERSION="16"
ARG PG_PORT="5432"

# --- Limit resource ---

LIMITS cpu ${CPULIMIT}
LIMITS memoryuse ${MEMLIMIT}
LIMITS datasize 20G ${DISKLIMIT}

# --- Config ---
CONFIG set allow.raw_sockets 1
CONFIG set allow.sysvipc 1
CONFIG set sysvshm new
CONFIG set sysvsem new
RESTART

# install required templates
INCLUDE https://github.com/bastille-templates/mysql
INCLUDE https://github.com/bastille-templates/redis
INCLUDE https://github.com/bastille-templates/nginx

# install required packages

PKG bash ca_root_nss nano librenms python3 php84-opcache py311-redis-7.2.0

# Render File

CP usr /
CP root /

RENDER /usr/local/etc/mysql/my.cnf
RENDER /usr/local/etc//redis.conf
RENDER /root/init.sh

# Commmand Jail

CMD sh init.sh && rm init.sh

RESTART

#RDR tcp ${PG_PORT} 5432

TAGS monitoring-tool