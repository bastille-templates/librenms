# --- Config ---
CONFIG set allow.raw_sockets 1
CONFIG set allow.sysvipc 1
CONFIG set sysvshm new
CONFIG set sysvsem new
RESTART

# install required templates
INCLUDE https://github.com/bastille-templates/base

PKG bash ca_root_nss nano

CMD chsh -s /usr/local/bin/bash root

# install required packages
PKG nginx librenms python3 php84-opcache mysql80-server redis74 py311-redis-7.4.0

# Render File
CP etc /
CP usr /
CP root /

RENDER /etc/hosts
RENDER /usr/local/etc/mysql/my.cnf
RENDER /usr/local/etc/redis.conf
RENDER /root/init.sh

# Commmand Jail
CMD bash init.sh && rm init.sh

RDR tcp 80 80
RDR tcp 443 443

TAGS monitoring-tool