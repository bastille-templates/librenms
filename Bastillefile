# --- Variable ---

ARG CPULIMIT="0,1"
ARG MEMLIMIT="2048M"
ARG DISKLIMIT="4G"

ARG PG_VERSION="16"
ARG PG_PORT="5432"

# --- Limit resource ---

LIMITS cpu ${CPULIMIT}
LIMITS memoryuse ${MEMLIMIT}
LIMITS datasize 20G ${DISKLIMIT}

# --- Config ---

CONFIG set allow.sysvipc 1
CONFIG set sysvshm new
CONFIG set sysvsem new
RESTART

# install required templates

INCLUDE https://github.com/bastille-templates/mysql
INCLUDE https://github.com/bastille-templates/nginx

# install required packages

PKG librenms mysql84-server python3 nginx php84-opcache

# enable and start postgre

SYSRC postgresql_enable=YES
SYSRC postgresql_data="/var/db/postgres/data${PG_VERSION}"

SERVICE postgresql initdb

SERVICE postgresql start

#RDR tcp ${PG_PORT} 5432

TAGS database postgresql pg${PG_VERSION}
